---
import Layout from "@/layouts/Layout.astro";
import Navbar from "@/components/layout/Navbar.astro";
import WorldCreationLoader from "@/components/worlds/WorldCreationLoader.astro";
---
<Layout title="Create World | Vanta Labs">

  <Navbar />

  <WorldCreationLoader />

  <main class="min-h-screen bg-background px-4 pt-24 sm:px-6 lg:px-8">

    <section class="mx-auto max-w-2xl">

      <div class="mb-10">

        <p class="mb-2 text-sm text-muted-foreground">
          Collaborative Infrastructure
        </p>

        <h1 class="text-4xl font-semibold tracking-tight">
          Create World
        </h1>

      </div>

      <form
        id="world-form"
        class="space-y-6"
      >

        <div>
            <label class="mb-2 block text-sm font-medium">
            World Name
          </label>
          <div>

  <label class="mb-2 block text-sm font-medium">
    World Code
  </label>

  <input
    id="world-code"
    type="text"
    maxlength="8"
    placeholder="CORE"
    class="w-full rounded-2xl border border-border bg-background px-4 py-4 uppercase outline-none transition focus:border-muted-foreground"
  />

  <p class="mt-2 text-xs text-muted-foreground">
    3–8 letters or numbers. No spaces or symbols.
  </p>

</div>

          <input
            id="world-name"
            type="text"
            placeholder="Nova Forge"
            class="w-full rounded-2xl border border-border bg-background px-4 py-4 outline-none transition focus:border-muted-foreground"
          />

        </div>

        <div
  id="world-preview"
  class="rounded-xl border border-border bg-muted/30 px-4 py-4 text-sm text-muted-foreground"
>
  /dashboard/loading...
</div>

        <button
          type="submit"
          class="w-full rounded-2xl bg-white px-6 py-4 text-sm font-medium text-black transition hover:opacity-90"
        >
          Forge World
        </button>

      </form>

    </section>
    </main>

</Layout>

<script>
  import { createWorld } from "@/lib/workspaces";

  const form = document.getElementById(
    "world-form"
  );

  const loader = document.getElementById(
    "world-loader"
  );

  function updatePreview() {
  const worldName =
    input.value
      .toLowerCase()
      .replace(/\\s+/g, "-");

  const worldCode =
    codeInput.value.toUpperCase();

  const user =
    JSON.parse(
      localStorage.getItem(
        "activeWorkspace"
      ) || "{}"
    );

  const initials =
    user.name
      ?.split(" ")
      .map((part: string) =>
        part.charAt(0).toUpperCase()
      )
      .join("")
      .slice(0, 2) || "XX";

  preview.textContent =
    `/dashboard/${worldName}-${initials}-${worldCode}`;
}

input.addEventListener(
  "input",
  updatePreview
);

codeInput.addEventListener(
  "input",
  () => {
    codeInput.value =
      codeInput.value.replace(
        /[^a-zA-Z0-9]/g,
        ""
      );

    updatePreview();
  }
);

  form?.addEventListener(
    "submit",
    async (event) => {
      event.preventDefault();

      const input = document.getElementById(
        "world-name"
      ) as HTMLInputElement;

      const codeInput = document.getElementById(
  "world-code"
) as HTMLInputElement;

const preview = document.getElementById(
  "world-preview"
);

      const name = input.value;
      const code =
  codeInput.value.toUpperCase();

if (
  !/^[A-Z0-9]{3,8}$/.test(code)
) {
  alert(
    "World code must be 3–8 letters or numbers."
  );

  return;
}

      if (!name) return;

      loader?.classList.remove("hidden");

      try {
        await new Promise((resolve) =>
          setTimeout(resolve, 2600)
        );

        const world =
  await createWorld(
    name,
    code
  );

        localStorage.setItem(
          "activeWorkspace",
          JSON.stringify(world)
        );

        window.location.href = "/dashboard";
      } catch (error) {
        console.error(error);

        loader?.classList.add("hidden");

        alert(
          "Failed to create world."
        );
      }
    }
  );
</script>