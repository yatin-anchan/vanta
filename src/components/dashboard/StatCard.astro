---
interface Props {
  title: string;
  value: string | number;
}

const { title, value } = Astro.props;
---

<div class="rounded-2xl border border-border bg-card p-6 transition hover:border-muted-foreground/30">
  
  <p class="mb-2 text-sm text-muted-foreground">
    {title}
  </p>

  <h2 class="text-3xl font-semibold tracking-tight">
    {value}
  </h2>

</div>