---
const navItems = [
  { label: "Providers", href: "/providers" },
  { label: "Sandbox", href: "/sandbox" },
  { label: "Dashboard", href: "/dashboard" },
];
---

<header class="fixed top-0 z-50 w-full border-b border-border/50 bg-background/80 backdrop-blur-xl">
  <div class="mx-auto flex h-16 max-w-7xl items-center justify-between px-4 sm:px-6 lg:px-8">

    <a
      href="/"
      class="text-lg font-semibold tracking-tight"
    >
      Vanta.io
    </a>

    <nav class="hidden items-center gap-6 md:flex">
      {
        navItems.map((item) => (
          <a
            href={item.href}
            class="text-sm text-muted-foreground transition hover:text-foreground"
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <a
      href="https://github.com"
      target="_blank"
      class="rounded-md border border-border px-4 py-2 text-sm transition hover:bg-muted"
    >
      GitHub
    </a>

  </div>
</header>