---
import { Menu } from "lucide-astro";
import { LogOut } from "lucide-astro";
import WorkspaceSwitcher from "./WorkspaceSwitcher.astro";

const navItems = [
  { label: "Providers", href: "/providers" },
  { label: "Sandbox", href: "/sandbox" },
  { label: "Dashboard", href: "/dashboard" },
];
---

<header class="fixed top-0 z-50 w-full border-b border-border/50 bg-background/80 backdrop-blur-xl">
  
  <div class="mx-auto flex h-16 max-w-7xl items-center justify-between px-4 sm:px-6 lg:px-8">

    <a
      href="/"
      class="text-lg font-semibold tracking-tight"
    >
      Vanta.io
    </a>

    <nav class="hidden items-center gap-6 md:flex">
      {
        navItems.map((item) => (
          <a
            href={item.href}
            class="text-sm text-muted-foreground transition hover:text-foreground"
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-3">
      <WorkspaceSwitcher />
      <button
  id="logout-button"
  class="hidden rounded-md border border-border px-4 py-2 text-sm transition hover:bg-muted sm:block"
>
  Logout
</button>
      <a
        href="https://github.com"
        target="_blank"
        class="hidden rounded-md border border-border px-4 py-2 text-sm transition hover:bg-muted sm:block"
      >
        GitHub
      </a>

      <button
        class="flex h-10 w-10 items-center justify-center rounded-md border border-border md:hidden"
      >
        <Menu class="h-5 w-5" />
      </button>

    </div>

  </div>

</header>

<script>
  import { signOut } from "@/lib/auth";

  const logoutButton =
    document.getElementById("logout-button");

  logoutButton?.addEventListener(
    "click",
    async () => {
      await signOut();

      window.location.href = "/";
    }
  );
</script>