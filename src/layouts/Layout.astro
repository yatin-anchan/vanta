---
import "@/styles/global.css";


interface Props {
  title?: string;
}

const { title = "Vanta.io" } = Astro.props;
---

<!DOCTYPE html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content="Developer-first payment sandbox infrastructure platform." />
    <title>{title}</title>
  </head>

  <body class="min-h-screen bg-background text-foreground antialiased">
    
    <slot />
  </body>
</html>